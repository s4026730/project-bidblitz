<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="1000" prefWidth="1710" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bidblitz.MainController">
    <Button styleClass="navigationBarButton" />
    <top>
        <ToolBar prefHeight="40.0" prefWidth="200.0" styleClass="navigationBar">
            <items>
                <Button mnemonicParsing="false" onAction="#switchToGuestHome" styleClass="navigationBarButton, homeButton" text="BIDBLITZ" />
                <Button layoutX="10.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestAuction" styleClass="navigationBarButton" text="AUCTION" />
                <Button layoutX="66.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestCategory" styleClass="navigationBarButton" text="CATEGORY" />
                <TextField promptText="Search Bar" styleClass="searchBar" />
                <Button layoutX="122.0" layoutY="12.0" mnemonicParsing="false" styleClass="navigationBarButton" text="Button" />
                <Button layoutX="195.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestHelp" styleClass="navigationBarButton" text="HELP" />
                <Button layoutX="251.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestAboutUs" styleClass="navigationBarButton" text="ABOUT US" />
                <Button layoutX="473.0" layoutY="10.0" mnemonicParsing="false" onAction="#switchToSignIn" styleClass="navigationBarButton" text="SIGN IN" />
                <Button layoutX="587.0" layoutY="10.0" mnemonicParsing="false" onAction="#switchToSignUp" styleClass="navigationBarButton" text="SIGN UP" />
            </items>
            <padding>
                <Insets top="-1.0" />
            </padding>
        </ToolBar>
    </top>

    <center>
        <AnchorPane>
            <Label fx:id="signupLabel" styleClass="importantText" layoutX="633.0" layoutY="7.0" text="Create your account:" />
            <Label fx:id="signupUsername" styleClass="importantText" layoutX="527.0" layoutY="65.0" text="Username:" />
            <Label fx:id="signupEmail" styleClass="importantText" layoutX="527.0" layoutY="175.0" text="Email:" />
            <Label fx:id="signupPassword" styleClass="importantText" layoutX="527.0" layoutY="285.0" text="Password:" />
            <TextField layoutX="527.0" layoutY="123.0" styleClass="signupTextfield" />
            <TextField layoutX="527.0" layoutY="233.0" styleClass="signupTextfield" />
            <TextField layoutX="527.0" layoutY="352.0" styleClass="signupTextfield" />
            <Button fx:id="signupButton" styleClass="actionButton" layoutX="527.0" layoutY="446.0" prefWidth="600" mnemonicParsing="false" text="Sign Up" />
            <Text styleClass="OR" layoutX="799.0" layoutY="562.0" strokeType="OUTSIDE" strokeWidth="0.0" text="OR" />
            <Button fx:id="signupGoogleButton" styleClass="actionButton" layoutX="527.0" layoutY="590.0" prefWidth="600"
                    text="Sign Up With Google" textAlignment="CENTER">
                <graphic>
                <ImageView fitHeight="40.0" fitWidth="40.0" preserveRatio="true" smooth="true" styleClass="googleIcon">
                    <Image url="@../../../image/google-round-icon.png" />
                </ImageView>
                </graphic>
            </Button>
            <Hyperlink styleClass="actionHyperLink" layoutX="655.0" layoutY="695.0" onAction="#switchToSignIn" text="Already have an account? Click here" />
        </AnchorPane>
    </center>

    <bottom>

    </bottom>
    <stylesheets>
        <URL value="@../../../css/General.css" />
    </stylesheets>
</BorderPane>
