<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="1000" prefWidth="1710" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25"
            fx:controller="com.example.bidblitz.MainController">
    <Button styleClass="navigationButton"></Button>
    <top>
        <ToolBar prefHeight="40.0" prefWidth="200.0" styleClass="navigationBar">
            <items>
                <Button mnemonicParsing="false" styleClass="navigationButton, homeButton" text="BIDBLITZ"
                        onAction="#switchToGuestHome">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Button>
                <Button layoutX="10.0" layoutY="12.0" mnemonicParsing="false" styleClass="navigationButton" text="AUCTION"
                        onAction="#switchToGuestAuction">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Button>
                <Button layoutX="66.0" layoutY="12.0" mnemonicParsing="false" styleClass="navigationButton" text="CATEGORY"
                        onAction="#switchToGuestCategory">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Button>
                <TextField promptText="Search Bar" styleClass="searchBar">
                    <font>
                        <Font size="20.0" />
                    </font>
                </TextField>
                <Button layoutX="122.0" layoutY="12.0" mnemonicParsing="false" styleClass="navigationButton" text="Button">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Button>
                <Button layoutX="195.0" layoutY="12.0" mnemonicParsing="false" styleClass="navigationButton" text="HELP"
                        onAction="#switchToGuestHelp">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Button>
                <Button layoutX="251.0" layoutY="12.0" mnemonicParsing="false" styleClass="navigationButton" text="ABOUT US"
                        onAction="#switchToGuestAboutUs">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Button>
                <Button layoutX="473.0" layoutY="10.0" mnemonicParsing="false" styleClass="navigationButton" text="SIGN IN"
                        onAction="#switchToGuestSignIn">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Button>
                <Button layoutX="587.0" layoutY="10.0" mnemonicParsing="false" styleClass="navigationButton" text="SIGN UP"
                        onAction="#switchToGuestSignUp">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Button>
            </items>
            <padding>
                <Insets top="-1.0" />
            </padding>
        </ToolBar>
    </top>

    <center>
        <Label>SIGN UP</Label>
    </center>

    <bottom>

    </bottom>
    <stylesheets>
        <URL value="@../../../css/General.css" />
    </stylesheets>
</BorderPane>