                    <Button fx:id="kitchenTools" maxHeight="30" maxWidth="225" minHeight="30" minWidth="225" mnemonicParsing="false" prefHeight="30.0" prefWidth="225" styleClass="textButton" text="Kitchen Tools" />
                    <Button fx:id="cookwares" maxHeight="30" maxWidth="225" minHeight="30" minWidth="225" mnemonicParsing="false" prefHeight="30.0" prefWidth="225" styleClass="textButton" text="Cookwares" />
                    <Button fx:id="cookingBooks" maxHeight="30" maxWidth="225" minHeight="30" minWidth="225" mnemonicParsing="false" prefHeight="30.0" prefWidth="225" styleClass="textButton" text="Cooking Books" />
                </HBox>
                <HBox maxHeight="30.0" maxWidth="1380" minHeight="30.0" minWidth="1380" prefHeight="30.0" prefWidth="1380" styleClass="categoryRow">
