                    <Button fx:id="computerParts" maxHeight="30" maxWidth="225" minHeight="30" minWidth="225" mnemonicParsing="false" prefHeight="30.0" prefWidth="225" styleClass="textButton" text="Computer Parts" />
                    <Button fx:id="mobilePhoneParts" maxHeight="30" maxWidth="225" minHeight="30" minWidth="225" mnemonicParsing="false" prefHeight="30.0" prefWidth="225" styleClass="textButton" text="Mobile Phone Parts" />
                    <Button fx:id="tabletPart" maxHeight="30" maxWidth="225" minHeight="30" minWidth="225" mnemonicParsing="false" prefHeight="30.0" prefWidth="225" styleClass="textButton" text="Tablet Parts" />
                </HBox>
                <HBox maxHeight="30.0" maxWidth="1380" minHeight="30.0" minWidth="1380" prefHeight="30.0" prefWidth="1380" styleClass="categoryRow">
                    <Button fx:id="meats" maxHeight="30" maxWidth="225" minHeight="30" minWidth="225" mnemonicParsing="false" prefHeight="30.0" prefWidth="225" styleClass="textButton" text="Meats" />
