<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Separator?>
<BorderPane prefHeight="1000" prefWidth="1710" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bidblitz.MainController">
    <Button styleClass="navigationButton" />
    <top>
        <ToolBar prefHeight="40.0" prefWidth="200.0" styleClass="navigationBar">
            <items>
                <Button mnemonicParsing="false" onAction="#switchToGuestHome" styleClass="navigationButton, homeButton" text="BIDBLITZ" />
                <Button layoutX="10.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestAuction" styleClass="navigationButton" text="AUCTION" />
                <Button layoutX="66.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestCategory" styleClass="navigationButton" text="CATEGORY" />
                <TextField promptText="Search Bar" styleClass="searchBar" />
                <Button layoutX="122.0" layoutY="12.0" mnemonicParsing="false" styleClass="navigationButton" text="Button" />
                <Button layoutX="195.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestHelp" styleClass="navigationButton" text="HELP" />
                <Button layoutX="251.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestAboutUs" styleClass="navigationButton" text="ABOUT US" />
                <Button layoutX="473.0" layoutY="10.0" mnemonicParsing="false" onAction="#switchToSignIn" styleClass="navigationButton" text="SIGN IN" />
                <Button layoutX="587.0" layoutY="10.0" mnemonicParsing="false" onAction="#switchToSignUp" styleClass="navigationButton" text="SIGN UP" />
            </items>
            <padding>
                <Insets top="-1.0" />
            </padding>
        </ToolBar>
    </top>

    <center>
        <AnchorPane>
            <Label layoutX="800" styleClass="importantText" text="ABOUT US" />
            <TitledPane expanded="false" layoutX="433.0" layoutY="132.0" styleClass="collapsibleContainer" text="What and Why?">
                <content>
                    <VBox spacing="5">
                        <Label wrapText="true" maxWidth="300">
                            <text>
                                BidBlitz is an online auction and trading platform that recreates the experience of traditional
                                in person auctions in a digital space. It supports seamless user to user communication,
                                maintains secure and detailed transaction tracking, logging and delivers a simple, user-friendly interface.
                            </text>
                        </Label>
                        <Separator maxWidth="200" halignment="CENTER" visible="false"/>
                        <Label wrapText="true" maxWidth="300">
                            <text>
                                BidBlitz serves for kind of matters except those that 100% related to serious crime
                            </text>
                        </Label>
                    </VBox>
                </content>
            </TitledPane>
            <TitledPane expanded="false" layoutX="786.0" layoutY="132.0" styleClass="collapsibleContainer" text="Rules">
                <content>
                    <VBox spacing="5">
                        <Label wrapText="true" maxWidth="300"
                               text="1. Respects to each others and be professional. Racism and hatred comments are strictly prohibited" />
                    </VBox>
                </content>
            </TitledPane>
            <TitledPane expanded="false" layoutX="1145.0" layoutY="132.0" styleClass="collapsibleContainer" text="Further Development">
                <content>
                    <VBox spacing="5">
                        <Label wrapText="true" maxWidth="300"
                               text="As for now, we plan to refine the application core fundamental functionalities and developing effective quality measurement and assurance procedure to ensure the rights for the customers." />
                    </VBox>
                </content>
            </TitledPane>
        </AnchorPane>
    </center>

    <bottom>


    </bottom>
    <stylesheets>
        <URL value="@../../../css/General.css" />
    </stylesheets>
</BorderPane>
