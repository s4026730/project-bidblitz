<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="1000" prefWidth="1710" styleClass="lightPageLayout" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bidblitz.MainController">
    <top>
        <AnchorPane maxHeight="50.0" prefHeight="50.0">
            <Button layoutY="-41.0" styleClass="sideBarButton" />
            <Button alignment="CENTER" maxHeight="50.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToGuestHome" prefHeight="50.0" prefWidth="200.0" text="BIDBLITZ" textAlignment="CENTER">
                <styleClass>
                    <String fx:value="navigationButton" />
                    <String fx:value="homeButton" />
                </styleClass>
            </Button>
            <MenuButton layoutX="230.0" maxHeight="50.0" maxWidth="200.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="200.0" styleClass="textButton" text="CATEGORY" textAlignment="CENTER">
                <items>
                    <MenuItem mnemonicParsing="false" text="Action 1" />
                    <MenuItem mnemonicParsing="false" text="Action 2" />
                    <MenuItem mnemonicParsing="false" text="Unspecified Action" />
                </items>
            </MenuButton>
            <TextField layoutX="420.0" maxHeight="50.0" maxWidth="450.0" prefHeight="50.0" prefWidth="450.0" promptText="🔍 Search For Anything" styleClass="searchBar" />
            <Button id="searchButton" layoutX="900.0" maxHeight="50.0" maxWidth="100.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="100.0" text="SEARCH" textAlignment="CENTER" />
            <Button id="advanceSearchButton" layoutX="1030.0" maxHeight="50.0" maxWidth="200.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="200.0" text="ADVANCE SEARCH" textAlignment="CENTER" />
            <Button alignment="CENTER" layoutX="1310.0" maxHeight="50.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToSignIn" prefHeight="50.0" prefWidth="200.0" styleClass="navigationButton" text="SIGN IN" textAlignment="CENTER" />
            <Button alignment="CENTER" layoutX="1510.0" maxHeight="50.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToSignUp" prefHeight="50.0" prefWidth="200.0" styleClass="navigationButton" text="SIGN UP" textAlignment="CENTER" />
        </AnchorPane>
    </top>
    <left>
        <VBox maxHeight="1000.0" maxWidth="200.0" prefHeight="1000.0" prefWidth="200.0" styleClass="sidebarMenu" BorderPane.alignment="TOP_LEFT">
            <AnchorPane maxHeight="1000.0" maxWidth="200.0" prefHeight="1000.0" prefWidth="200.0">
                <children>
                    <Button alignment="CENTER" maxHeight="100.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToGuestAuction" prefHeight="100.0" prefWidth="200.0" styleClass="navigationButton" text="AUCTION" textAlignment="CENTER" />
                    <Button alignment="CENTER" layoutY="100.0" maxHeight="100.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToGuestHelp" prefHeight="100.0" prefWidth="200.0" styleClass="navigationButton" text="HELP" textAlignment="CENTER" />
                    <Button alignment="CENTER" layoutY="200.0" maxHeight="100.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToGuestAboutUs" prefHeight="100.0" prefWidth="200.0" styleClass="navigationButton" text="ABOUT US" textAlignment="CENTER" />
                    <Button alignment="CENTER" layoutY="300.0" maxHeight="100.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToSignIn" prefHeight="100.0" prefWidth="200.0" styleClass="navigationButton" text="SIGN IN" textAlignment="CENTER" />
                    <Button alignment="CENTER" layoutY="400.0" maxHeight="100.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToSignUp" prefHeight="100.0" prefWidth="200.0" styleClass="navigationButton" text="SIGN UP" textAlignment="CENTER" />
                </children>
            </AnchorPane>
        </VBox>
    </left>
    <center>
        <AnchorPane maxHeight="950.0" maxWidth="1510.0" prefHeight="950.0" prefWidth="1510.0">
            <Label layoutX="680.0" layoutY="50.0" styleClass="importantText" text="ABOUT US" />
            <TitledPane expanded="false" layoutX="80.0" layoutY="110.0" maxHeight="900" maxWidth="400.0"
                        prefHeight="45.0" prefWidth="400.0" styleClass="collapsibleContainer" text="What and Why?">
                <content>
                    <VBox spacing="5" fillWidth="true">
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                BidBlitz is an online auction and trading platform that recreates the experience of traditional
                                in person auctions in a digital space.
                            </text>
                        </Label>
                        <Separator halignment="CENTER"
                                   maxWidth="200"
                                   visible="false"/>
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                It supports seamless user to user communication, maintains secure and detailed transaction tracking,
                                logging and delivers a simple, user-friendly interface.
                            </text>
                        </Label>
                    </VBox>
                </content>
            </TitledPane>

            <TitledPane expanded="false" layoutX="550.0" layoutY="110.0" maxHeight="900.0" maxWidth="400.0"
                        prefHeight="45.0" prefWidth="400.0" styleClass="collapsibleContainer" text="Rules">

                <content>
                    <VBox spacing="5" fillWidth="true">
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                1) Users must communicate respectfully and may not engage in harassment, threats or abusive behavior.
                            </text>
                        </Label>
                        <Separator maxWidth="200" visible="false"/>
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                2) Users must provide accurate and truthful account information during registration.
                            </text>
                        </Label>
                        <Separator maxWidth="200" visible="false"/>
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                3) Users must provide accurate and truthful account information during registration.
                            </text>
                        </Label>
                        <Separator maxWidth="200" visible="false"/>
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                4) All bids placed by users are considered final and legally binding once submitted.
                            </text>
                        </Label>
                        <Separator maxWidth="200" visible="false"/>
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                5) Sellers are required to auction only legal, authentic and permitted items,
                                accompanied by accurate descriptions, relevant images and clear condition details.
                            </text>
                        </Label>
                        <Separator maxWidth="200" visible="false"/>
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                6) Sellers are strictly prohibited from bidding on their own auction listings.
                            </text>
                        </Label>
                        <Separator maxWidth="200" visible="false"/>
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                7) Winning bidders must complete payment within the specified payment period.
                            </text>
                        </Label>
                        <Separator maxWidth="200" visible="false"/>
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                8) Fraudulent activities, fake bids, scams and price manipulation are strictly prohibited.
                            </text>
                        </Label>
                        <Separator maxWidth="200" visible="false"/>
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                9) The platform reserves the right to suspend or permanently ban accounts
                                that violate marketplace policies.
                            </text>
                        </Label>
                        <Separator maxWidth="200" visible="false"/>
                        <Label prefWidth="300" wrapText="true">
                            <text>
                                10) All transactions, bidding activities and user interactions are securely monitored and recorded
                                to ensure platform security, transparency and fairness.
                            </text>
                        </Label>
                    </VBox>
                </content>
            </TitledPane>

            <TitledPane expanded="false" layoutX="1020.0" layoutY="110.0" maxHeight="900.0" maxWidth="400.0" prefHeight="45.0"
                        prefWidth="400.0" styleClass="collapsibleContainer" text="Further Development">
                <content>
                    <VBox spacing="5" fillWidth="true">
                        <Label prefWidth="300" wrapText="true"
                               text="As for now, we plan to refine the application core fundamental functionalities and developing
                               effective quality measurement and assurance procedure to ensure the rights for the customers."/>
                    </VBox>
                </content>
            </TitledPane>

        </AnchorPane>
    </center>
    <stylesheets>
        <URL value="@../../../css/General.css" />
    </stylesheets>
</BorderPane>
