<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ScrollPane?>
<BorderPane prefHeight="1000" prefWidth="1710" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bidblitz.MainController">
    <Button styleClass="navigationButton" />
    <top>
        <ToolBar prefHeight="40.0" prefWidth="200.0" styleClass="navigationBar">
            <items>
                <Button mnemonicParsing="false" onAction="#switchToGuestHome" styleClass="navigationButton, homeButton" text="BIDBLITZ" />
                <Button layoutX="10.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestAuction" styleClass="navigationButton" text="AUCTION" />
                <Button layoutX="66.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestCategory" styleClass="navigationButton" text="CATEGORY" />
                <TextField promptText="Search Bar" styleClass="searchBar" />
                <Button layoutX="122.0" layoutY="12.0" mnemonicParsing="false" styleClass="navigationButton" text="Button" />
                <Button layoutX="195.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestHelp" styleClass="navigationButton" text="HELP" />
                <Button layoutX="251.0" layoutY="12.0" mnemonicParsing="false" onAction="#switchToGuestAboutUs" styleClass="navigationButton" text="ABOUT US" />
                <Button layoutX="473.0" layoutY="10.0" mnemonicParsing="false" onAction="#switchToSignIn" styleClass="navigationButton" text="SIGN IN" />
                <Button layoutX="587.0" layoutY="10.0" mnemonicParsing="false" onAction="#switchToSignUp" styleClass="navigationButton" text="SIGN UP" />
            </items>
            <padding>
                <Insets top="-1.0" />
            </padding>
        </ToolBar>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" pannable="true">
            <AnchorPane>
                <Label layoutX="800" styleClass="importantText" text="ABOUT US" />
                <TitledPane maxHeight="900" maxWidth="300" expanded="false" layoutX="433.0" layoutY="84.0" styleClass="collapsibleContainer" text="What and Why?">
                    <content>
                        <VBox spacing="5">
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    BidBlitz is an online auction and trading platform that recreates the experience of traditional
                                    in person auctions in a digital space.
                                </text>
                            </Label>
                            <Separator halignment="CENTER" maxWidth="200" visible="false" />
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    It supports seamless user to user communication, maintains secure and detailed transaction tracking,
                                    logging and delivers a simple, user-friendly interface.
                                </text>
                            </Label>
                        </VBox>
                    </content>
                </TitledPane>
                <TitledPane expanded="false" layoutX="787.0" layoutY="84.0" styleClass="collapsibleContainer" text="Rules">
                    <content>
                        <VBox spacing="5">
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    1) Users must communicate respectfully and may not engage in harassment, threats or abusive behavior.
                                </text>
                            </Label>
                            <Separator halignment="CENTER" maxWidth="200" visible="false" />
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    2) Users must provide accurate and truthful account information during registration.
                                </text>
                            </Label>
                            <Separator halignment="CENTER" maxWidth="200" visible="false" />
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    3) Users must provide accurate and truthful account information during registration.
                                </text>
                            </Label>
                            <Separator halignment="CENTER" maxWidth="200" visible="false" />
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    4) All bids placed by users are considered final and legally binding once submitted.
                                </text>
                            </Label>
                            <Separator halignment="CENTER" maxWidth="200" visible="false" />
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    5) Sellers are required to auction only legal, authentic and permitted items,
                                    accompanied by accurate descriptions, relevant images and clear condition details.
                                </text>
                            </Label>
                            <Separator halignment="CENTER" maxWidth="200" visible="false" />
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    6) Sellers are strictly prohibited from bidding on their own auction listings.
                                </text>
                            </Label>
                            <Separator halignment="CENTER" maxWidth="200" visible="false" />
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    7) Winning bidders must complete payment within the specified payment period.
                                </text>
                            </Label>
                            <Separator halignment="CENTER" maxWidth="200" visible="false" />
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    8) Fraudulent activities, fake bids, scams and price manipulation are strictly prohibited.
                                </text>
                            </Label>
                            <Separator halignment="CENTER" maxWidth="200" visible="false" />
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    9) The platform reserves the right to suspend or permanently ban accounts
                                    that violate marketplace policies.
                                </text>
                            </Label>
                            <Separator halignment="CENTER" maxWidth="200" visible="false" />
                            <Label maxWidth="300" wrapText="true">
                                <text>
                                    10) All transactions, bidding activities and user interactions are securely monitored and recorded
                                    to ensure platform security, transparency and fairness.
                                </text>
                            </Label>
                        </VBox>
                    </content>
                </TitledPane>
                <TitledPane expanded="false" layoutX="1146.0" layoutY="84.0" styleClass="collapsibleContainer" text="Further Development">
                    <content>
                        <VBox spacing="5">
                            <Label maxWidth="300" text="As for now, we plan to refine the application core fundamental functionalities and developing effective quality measurement and assurance procedure to ensure the rights for the customers." wrapText="true" />
                        </VBox>
                    </content>
                </TitledPane>
            </AnchorPane>
        </ScrollPane>
    </center>

    <bottom>


    </bottom>
    <stylesheets>
        <URL value="@../../../css/General.css" />
    </stylesheets>
</BorderPane>
