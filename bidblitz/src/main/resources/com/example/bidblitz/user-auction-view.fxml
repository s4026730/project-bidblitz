<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<AnchorPane prefHeight="1000" prefWidth="1710" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bidblitz.MainController">
    <VBox maxHeight="1000.0" maxWidth="200.0" prefHeight="1000.0" prefWidth="200.0" style="-fx-background-color: #B6D0E2;" BorderPane.alignment="TOP_LEFT">
        <AnchorPane maxHeight="1000.0" maxWidth="200.0" prefHeight="1000.0" prefWidth="200.0">
            <children>
                <Button alignment="CENTER" maxHeight="125.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToUserHome" prefHeight="125.0" prefWidth="200.0" text="BIDBLITZ" textAlignment="CENTER">
                    <styleClass>
                        <String fx:value="sideBarButton" />
                        <String fx:value="homeButton" />
                    </styleClass>
                </Button>
                <Button alignment="CENTER" layoutY="125.0" maxHeight="125.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToProfile"
                        prefHeight="125.0" prefWidth="200.0" styleClass="sideBarButton" text="PROFILE" textAlignment="CENTER" />
                <Button alignment="CENTER" layoutY="250.0" maxHeight="125.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToInventory"
                        prefHeight="125.0" prefWidth="200.0" styleClass="sideBarButton" text="INVENTORY" textAlignment="CENTER" />
                <Button alignment="CENTER" layoutY="375.0" maxHeight="125.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToTransactionHistory"
                        prefHeight="125.0" prefWidth="200.0" styleClass="sideBarButton" text="TRANSACTION HISTORY" textAlignment="CENTER" wrapText="true" />
                <Button alignment="CENTER" layoutY="500.0" maxHeight="125.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToUserHelp"
                        prefHeight="125.0" prefWidth="200.0" styleClass="sideBarButton" text="HELP" textAlignment="CENTER" />
                <Button alignment="CENTER" layoutY="625.0" maxHeight="125.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToUserAboutUs"
                        prefHeight="125.0" prefWidth="200.0" styleClass="sideBarButton" text="ABOUT US" textAlignment="CENTER" />
                <Button alignment="CENTER" layoutY="750.0" maxHeight="125.0" maxWidth="200.0" mnemonicParsing="false" onAction="#switchToSettings"
                        prefHeight="125.0" prefWidth="200.0" styleClass="sideBarButton" text="SETTINGS" textAlignment="CENTER" />
                <Button alignment="CENTER" layoutY="875.0" maxHeight="125.0" maxWidth="200.0" mnemonicParsing="false"
                        prefHeight="125.0" prefWidth="200.0" styleClass="sideBarButton" text="LOG OUT" textAlignment="CENTER" />
            </children>
        </AnchorPane>
    </VBox>
    <stylesheets>
        <URL value="@../../../css/General.css" />
    </stylesheets>
</AnchorPane>
